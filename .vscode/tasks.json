{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "start",
            "command": "npm",
            "args": ["start"],
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "build",
            "command": "npm",
            "args": ["run", "build"],
            "options": {
                "cwd": "${workspaceFolder}/app"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}